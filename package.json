{
  "name": "kiri-pens",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cd ./astro-site && astro dev",
    "build": "cd ./astro-site && astro build",
    "preview": "cd ./astro-site && astro preview",
    "astro": "astro",
