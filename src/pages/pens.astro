---
import BaseLayout from '../layouts/BaseLayout.astro';

const pens = [
  {
    id: 1,
    name: "Earl Blue",
    price: 225,
    nib: "Medium",
    material: "Resin",
    color: "Blue",
    description: "A smooth, reliable writer with a hand-polished resin body and custom-tuned nib. Resin construction offers excellent durability and resistance to wear. Features a luxury finish with an ergonomic design for extended writing comfort."
  }
];

---

<BaseLayout title="Our Pens - Kiri Pens">
  <section class="page-header">
    <h1>Our Pens</h1>
    <p class="section-intro">Each pen is handcrafted with meticulous attention to detail.</p>
  </section>

  <section class="product-grid">
    {pens.map(pen => (
      <article class="product-card">
        <div class="product-image">
          <img src="/pens/earl-blue.png" alt={pen.name} />
        </div>
        <div class="product-info">
          <h3>{pen.name}</h3>
          <p class="description">{pen.description}</p>
          <div class="specs">
            <span>Nib: {pen.nib}</span>
            <span>•</span>
            <span>{pen.material}</span>
          </div>
            <div class="price-row">
            <span class="price">£{pen.price}</span>
            <a href={`/contact?pen=${pen.id}`} class="inquire-btn">Inquire</a>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .section-intro {
    font-style: italic;
    opacity: 0.8;
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-border);
    background: white;
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.03em;
    transition: all 0.2s ease;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .product-image {
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;


    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-info {
    padding: 1.5rem;
  }

  .collection-tag {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .product-info h3 {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .specs {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .price {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .inquire-btn {
    padding: 0.5rem 1.25rem;
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .inquire-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
