---
import BaseLayout from '../layouts/BaseLayout.astro';

const pens = [
  {
    id: 1,
    name: "The Artisan",
    collection: "everyday",
    price: 185,
    nib: "Medium",
    material: "Ebonite",
    color: "Black & Gold",
    description: "A classic everyday writer with a smooth, reliable nib."
  },
  {
    id: 2,
    name: "Sakura Blossom",
    collection: "limited",
    price: 320,
    nib: "Fine",
    material: "Resin",
    color: "Pink Marbled",
    description: "Limited edition celebrating the fleeting beauty of spring."
  },
  {
    id: 3,
    name: "Monarch",
    collection: "luxury",
    price: 550,
    nib: "Broad",
    material: "Celluloid",
    color: "Amber & Brown",
    description: "Premium celluloid construction with 18K gold nib."
  },
  {
    id: 4,
    name: "The Scholar",
    collection: "everyday",
    price: 145,
    nib: "Fine",
    material: "Resin",
    color: "Burgundy",
    description: "Perfect for students and daily journaling."
  },
  {
    id: 5,
    name: "Winter's Rest",
    collection: "limited",
    price: 380,
    nib: "Medium",
    material: "Ebonite",
    color: "Frosted Blue",
    description: "Only 50 pieces made each winter season."
  },
  {
    id: 6,
    name: "Emperor",
    collection: "luxury",
    price: 890,
    nib: "Extra Broad",
    material: "Precious Resin",
    color: "Royal Blue",
    description: "Our flagship model with rhodium accents."
  },
  {
    id: 7,
    name: "The Correspondent",
    collection: "everyday",
    price: 165,
    nib: "Medium",
    material: "Ebonite",
    color: "Sea Green",
    description: "Ideal pen for long writing sessions."
  },
  {
    id: 8,
    name: "Golden Hour",
    collection: "limited",
    price: 425,
    nib: "Fine",
    material: "Urushi Lacquer",
    color: "Gold Flake",
    description: "Hand-lacquered with genuine gold dust."
  }
];

const collections = [
  { id: "everyday", name: "Everyday Writers", description: "Reliable pens for daily use" },
  { id: "limited", name: "Limited Editions", description: "Rare, collectible pieces" },
  { id: "luxury", name: "Luxury Series", description: "Premium materials and craftsmanship" }
];
---

<BaseLayout title="Our Pens - Kiri Pens">
  <section class="page-header">
    <h1>Our Pens</h1>
    <p class="section-intro">Each pen is handcrafted with meticulous attention to detail.</p>
  </section>

  <section class="filters">
    <a href="/pens" class="filter-btn active">All</a>
    {collections.map(collection => (
      <a href={`/pens?collection=${collection.id}`} class="filter-btn">{collection.name}</a>
    ))}
  </section>

  <section class="product-grid">
    {pens.map(pen => (
      <article class="product-card">
        <div class="product-image">
          <div class="pen-placeholder">✒</div>
        </div>
        <div class="product-info">
          <span class="collection-tag">{pen.collection}</span>
          <h3>{pen.name}</h3>
          <p class="description">{pen.description}</p>
          <div class="specs">
            <span>Nib: {pen.nib}</span>
            <span>•</span>
            <span>{pen.material}</span>
          </div>
          <div class="price-row">
            <span class="price">${pen.price}</span>
            <a href={`/contact?pen=${pen.id}`} class="inquire-btn">Inquire</a>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .section-intro {
    font-style: italic;
    opacity: 0.8;
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-border);
    background: white;
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.03em;
    transition: all 0.2s ease;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .product-card {
    background: white;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .product-image {
    height: 200px;
    background: linear-gradient(135deg, #f5f0e8 0%, #e8e0d4 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pen-placeholder {
    font-size: 4rem;
    color: var(--color-accent);
    opacity: 0.5;
  }

  .product-info {
    padding: 1.5rem;
  }

  .collection-tag {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .product-info h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .specs {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .price {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .inquire-btn {
    padding: 0.5rem 1.25rem;
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .inquire-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
