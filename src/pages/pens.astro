---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPens = Object.values(import.meta.glob('./pens/*.md', { eager: true }));
---

<BaseLayout title="Our Pens - Kiri Pens">
  <section class="page-header">
    <h1>Our Pens</h1>
    <p class="section-intro">Each pen is handcrafted with meticulous attention to detail.</p>
  </section>

  <section class="product-grid">
    {allPens.map(pen => (
      <article class="product-card">
        <div class="product-image">
          <img src={pen.frontmatter.image} alt={pen.frontmatter.name} />
        </div>
        <div class="product-info">
          <h3>{pen.frontmatter.name}</h3>
          <p class="description">{pen.frontmatter.description}</p>
          <div class="price-row">
            <span class="price">£{pen.frontmatter.price}</span>
            <a href="/contact" class="inquire-btn">Inquire</a>
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .section-intro {
    font-style: italic;
    opacity: 0.8;
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-border);
    background: white;
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.03em;
    transition: all 0.2s ease;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(280px, 350px));
    }
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, minmax(280px, 350px));
    }
  }

  @media (min-width: 1400px) {
    .product-grid {
      grid-template-columns: repeat(4, minmax(280px, 350px));
    }
  }

  .product-card {
    background: white;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .product-image {
    height: 15rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-info {
    padding: 1.5rem;
    padding-top: 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .collection-tag {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .product-info h3 {
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 0.5rem;
    line-height: 1.5;
    height: 6rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4 ;
    -webkit-box-orient: vertical;
    text-overflow: ellipsis;
  }

  .specs {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .price {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .inquire-btn {
    padding: 0.5rem 1.25rem;
    background: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .inquire-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
