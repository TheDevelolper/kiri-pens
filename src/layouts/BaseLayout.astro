---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Kiri Pens - Handcrafted fountain pens" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Lora:ital@0;1&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <header>
        <a href={base} class="logo">
          <img 
            class="logo-image" 
            src={`${base}kiri-logo.svg`} 
            alt="brand logo" 
          />
        </a>
        <ul class="nav-links">
          <li><a href={`${base}pens`}>Pens</a></li>
          <li><a href={`${base}accessories`}>Accessories</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}testimonials`}>Testimonials</a></li>
          <li><a href={`${base}contact`}>Contact</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-content">
        <p class="tagline">Crafting memories, one pen at a time.</p>
        <p>&copy; {new Date().getFullYear()} Kiri Pens. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #f4f7f5;
    --color-text: #3d3630;
    --color-accent: #004b38;
    --color-accent-light: #40916c;
    --color-border: #c5d6c8;
    --color-footer-bg: #1a3a2e;
    --color-footer-text: #e8e4df;
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Lora', Georgia, serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.2;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-accent-light);
  }

  header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 2rem;
    layout: grid;
    place-items:center;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display:block;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.05em;
  }

  .logo:hover {
    color: var(--color-accent);
  }

.logo-image { 
  height: 10rem;

}

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  main {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }

  footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    padding: 2rem;
    text-align: center;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-accent-light);
  }

  footer p {
    font-size: 0.9rem;
    opacity: 0.8;
  }
</style>
