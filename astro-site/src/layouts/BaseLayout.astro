---
interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Kiri Pens - Handcrafted fountain pens" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Lora:ital@0;1&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <div class="nav-header">
          <a href={base} class="logo">
            <img 
              class="logo-image" 
              src={`${base}kiri-logo.svg`} 
              alt="brand logo" 
            />
          </a>
          <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
          </button>
        </div>
        <ul class="nav-links">
          <li><button class="close-menu" aria-label="Close menu">&times;</button></li>
          <li><a href={`${base}pens`}>Pens</a></li>
          <li><a href={`${base}accessories`}>Accessories</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <!-- <li><a href={`${base}testimonials`}>Testimonials</a></li> -->
          <li><a href={`${base}contact`}>Contact</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="page-footer">
      <div class="footer-content">
        <p class="tagline">Crafting memories, one pen at a time.</p>
        <p>&copy; {new Date().getFullYear()} Kiri Pens. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #f4f7f5;
    --color-text: #3d3630;
    --color-accent: #004b38;
    --color-accent-light: #40916c;
    --color-border: #c5d6c8;
    --color-footer-bg: #1a3a2e;
    --color-footer-text: #e8e4df;
    --font-heading: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Lora', Georgia, serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2 {
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.2;
  }

  h3, h4, h5, h6 {
    font-family: var(--font-body);
    font-weight: 900;
    line-height: 1.3;
    font-size: 1.1rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-accent-light);
  }

  header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
  }

  .nav-header {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .logo {
    display: block;
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .logo-image {
    height: 8rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  main {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    width: 100%;
  }

  .page-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    padding: 2rem;
    text-align: center;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  th, td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
  }

  th {
    background: rgba(0, 75, 56, 0.05);
    font-weight: 600;
  }

  .tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-accent-light);
  }

  footer p {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    header {
      position: sticky;
      top: 0;
      z-index: 50;
    }

    nav {
      padding: 1rem;
    }

    .nav-header {
      margin-bottom: 1rem;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;

      margin: 3rem 2rem 2rem auto;
      
    }

    .hamburger .bar {
      width: 24px;
      height: 2px;
      background-color: var(--color-text);
      border-radius: 2px;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .hamburger.active .bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .hamburger.active .bar:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active .bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .logo-image {
      margin-top: 1.5rem;
      height: 7rem;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 70%;
      max-width: 280px;
      height: 100vh;
      background: var(--color-bg);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
      box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
      transition: right 0.3s ease;
      margin: 0;
      padding: 2rem;
    }

    .nav-links.active {
      right: 0;
    }

    .nav-links a {
      font-size: 1.2rem;
    }

    .close-menu {
      display: block;
      background: none;
      border: none;
      font-size: 2rem;
      cursor: pointer;
      color: var(--color-text);
      position: absolute;
      top: 1rem;
      right: 1.5rem;
      padding: 0;
      line-height: 1;
    }

    .close-menu:hover {
      color: var(--color-accent);
    }
  }

  @media (min-width: 769px) {
    .hamburger,
    .close-menu {
      display: none;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('.hamburger');
  const navLinks = document.querySelector('.nav-links');
  const closeMenu = document.querySelector('.close-menu');

  const closeNav = () => {
    hamburger?.classList.remove('active');
    navLinks?.classList.remove('active');
    hamburger?.setAttribute('aria-expanded', 'false');
  };

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    navLinks?.classList.toggle('active');
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', (!isExpanded).toString());
  });

  closeMenu?.addEventListener('click', closeNav);

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', closeNav);
  });
</script>
