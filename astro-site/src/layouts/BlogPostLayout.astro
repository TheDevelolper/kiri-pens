---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <p class="post-meta">
        <time datetime={frontmatter.modified}>{new Date(frontmatter.modified).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </p>
    </header>
    <div class="post-content">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .post-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-header h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .post-meta {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.8rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    font-weight: 700;
    font-size: 1.4rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h4) {
    font-weight: 700;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(h5) {
    font-weight: 700;
    font-size: 1.15rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(h6) {
    font-weight: 700;
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(code) {
    background: rgba(0, 75, 56, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    font-family: inherit;
    font-size: 0.9em;
    font-weight: 600;
    white-space: nowrap;
  }

  .post-content :global(blockquote) {
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.6;
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid var(--color-accent);
    background: rgba(0, 75, 56, 0.04);
    color: var(--color-text);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
